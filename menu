import requests
from bs4 import BeautifulSoup

# 1. ระบุ URL ที่ต้องการดึงข้อมูล
url = "https://www.wongnai.com/cooking" # เปลี่ยนเป็นเว็บที่ต้องการ
response = requests.get(url)

# 2. แปลงข้อมูลเป็น BeautifulSoup object
soup = BeautifulSoup(response.content, 'html.parser')

# 3. เลือกข้อมูลที่ต้องการ (เช่น ดึง tag <h1> ทั้งหมด)
titles = soup.find_all('h1')

for title in titles:
    print(title.text)
